# Citadel Governance API - Environment Configuration

# Application
APP_NAME=citadel-governance
APP_VERSION=0.1.0
DEBUG=false

# Database (REQUIRED)
DATABASE_URL=postgresql://citadel:citadel@postgres:5432/citadel
DB_MIN_SIZE=2
DB_MAX_SIZE=10

# API Security
# Comma-separated list of valid API keys
# At least one key required for production
API_KEYS=prod-key-change-me-now,dev-key-for-testing
REQUIRE_AUTH=true

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Metrics
METRICS_ENABLED=true
METRICS_ENDPOINT=/metrics
