# Citadel Runtime Environment Variables
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── Application ────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO

# ─── Database ───────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgresql://citadel:citadel@localhost:5432/citadel
DB_MIN_SIZE=2
DB_MAX_SIZE=10

# ─── Security ───────────────────────────────────────────────────────────────
# CHANGE ME: Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
CITADEL_JWT_SECRET=CHANGE_ME_IN_PRODUCTION_USE_STRONG_RANDOM_SECRET

# CHANGE ME: Format: "key1:scope1,scope2|key2:scope1"
# Example: "prod-api-key-1:admin|prod-api-key-2:read,write"
CITADEL_API_KEYS=CHANGE_ME_IN_PRODUCTION

# CHANGE ME: Bootstrap admin password (only used on first startup)
CITADEL_ADMIN_BOOTSTRAP_PASSWORD=CHANGE_ME_IN_PRODUCTION

# ─── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=https://citadelsdk.com,https://dashboard.citadelsdk.com

# ─── Rate Limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ─── Billing ────────────────────────────────────────────────────────────────
# Optional: Stripe integration
# STRIPE_SECRET_KEY=sk_live_...

# ─── Telemetry ──────────────────────────────────────────────────────────────
# Optional: OpenTelemetry OTLP endpoint
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
